# ── Production environment (server side) ─────────────────────────────────────
# Copy to `.env` next to docker-compose.prod.yml on your server and fill it in.
# `docker compose -f docker-compose.prod.yml` reads this automatically.

# Docker Hub image source (must match what you pushed)
DOCKER_USERNAME=yassinecherni9
TAG=latest

# ── Secrets (CHANGE THESE) ───────────────────────────────────────────────────
JWT_SECRET=medianet-super-secret-jwt-key-2024-medianet-incubation

# Postgres (shared user/password across the per-service databases)
POSTGRES_USER=medianet
POSTGRES_PASSWORD=change-me-strong-password

# RabbitMQ
RABBITMQ_USER=medianet
RABBITMQ_PASSWORD=change-me-strong-password

# MinIO object storage (logos, images, pitch videos)
MINIO_ROOT_USER=medianet
MINIO_ROOT_PASSWORD=change-me-strong-password
MINIO_BUCKET=medianet
# Public URL the BROWSER uses to load uploaded files.
# NO DOMAIN yet → use the server's public IP + the published MinIO port:
MINIO_PUBLIC_URL=http://YOUR_SERVER_IP:9000
# (With a domain later: https://app.yourdomain / an nginx-proxied path.)

# ── Email (Brevo/SMTP) — for invitations & notifications ─────────────────────
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=your-smtp-login
MAIL_PASSWORD=your-smtp-key
MAIL_FROM=you@example.com
MAIL_FROM_NAME=Medianet Incubateur

# Public URL of the front office (used in invitation email links)
FRONTEND_URL=http://YOUR_SERVER_IP:3000

# ── AI ───────────────────────────────────────────────────────────────────────
OLLAMA_MODEL=llama3.2
WHISPER_MODEL=base
PITCH_VISION_MODEL=moondream
# Optional hosted-LLM fallback for the admin AI (usually configured in the UI)
HF_TOKEN=
LLM_MODEL=
LLM_BASE_URL=

# ── Frontend API URLs — the address the BROWSER calls for the API ────────────
# These are baked into the frontend bundles at BUILD time (CI reads them from the
# repo Variables FRONTOFFICE_API_URL / BACKOFFICE_API_URL). NO DOMAIN yet → point
# both at the gateway on the server IP. Both frontends use the same gateway.
FRONTOFFICE_API_URL=http://YOUR_SERVER_IP:8080
BACKOFFICE_API_URL=http://YOUR_SERVER_IP:8080

# ── TLS (only when you add a domain + the nginx proxy profile) ───────────────
# TLS_FULLCHAIN=/etc/letsencrypt/live/yourdomain/fullchain.pem
# TLS_PRIVKEY=/etc/letsencrypt/live/yourdomain/privkey.pem
