# ─────────────────────────────────────────────────────────────
# Medianet Incubateur — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────

# ── Docker Hub ───────────────────────────────────────────────
DOCKER_USERNAME=yourdockerhubusername

# ── JWT (shared across all services) ─────────────────────────
JWT_SECRET=medianet-super-secret-jwt-key-2024-medianet-incubation
JWT_EXPIRATION=86400000

# ── PostgreSQL — Auth Service ─────────────────────────────────
POSTGRES_AUTH_DB=auth_db
POSTGRES_AUTH_USER=auth_user
POSTGRES_AUTH_PASSWORD=changeme_auth

# ── PostgreSQL — Session Service ──────────────────────────────
POSTGRES_SESSION_DB=session_db
POSTGRES_SESSION_USER=session_user
POSTGRES_SESSION_PASSWORD=changeme_session

# ── PostgreSQL — Candidature Service ─────────────────────────
POSTGRES_CANDIDATURE_DB=candidature_db
POSTGRES_CANDIDATURE_USER=candidature_user
POSTGRES_CANDIDATURE_PASSWORD=changeme_candidature

# ── PostgreSQL — Notification Service ────────────────────────
POSTGRES_NOTIFICATION_DB=notification_db
POSTGRES_NOTIFICATION_USER=notification_user
POSTGRES_NOTIFICATION_PASSWORD=changeme_notification

# ── PostgreSQL — Programme Service ───────────────────────────
POSTGRES_PROGRAMME_DB=programme_db
POSTGRES_PROGRAMME_USER=programme_user
POSTGRES_PROGRAMME_PASSWORD=changeme_programme

# ── Redis ─────────────────────────────────────────────────────
REDIS_PASSWORD=changeme_redis

# ── RabbitMQ ──────────────────────────────────────────────────
RABBITMQ_DEFAULT_USER=medianet
RABBITMQ_DEFAULT_PASS=changeme_rabbit

# ── Ollama (AI scoring / matching) ───────────────────────────
OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://ollama:11434

# ── HuggingFace Inference Providers (Admin AI Assistant) ─────
# Free token at https://huggingface.co/settings/tokens (role: Read).
# Tip: a 70B-class model is much more reliable for agentic tool use:
#   meta-llama/Llama-3.3-70B-Instruct
#   Qwen/Qwen2.5-72B-Instruct
#   mistralai/Mistral-Small-3.2-24B-Instruct-2506
#   deepseek-ai/DeepSeek-V3.1
# All these env vars are OPTIONAL — admin can also configure from the
# backoffice UI (Paramètres → Assistant IA). DB row takes precedence.
HF_TOKEN=
LLM_MODEL=
LLM_BASE_URL=

# ── Email (SMTP) ──────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=noreply@medianet.dz

# ── Next.js Frontoffice ───────────────────────────────────────
NEXT_PUBLIC_API_URL=https://app.medianet.dz

# ── Admin seed account ────────────────────────────────────────
ADMIN_EMAIL=admin@medianet.dz
ADMIN_PASSWORD=Admin1234!

# ── Deploy (set these as GitHub Secrets, not here) ───────────
# DEPLOY_HOST=your-vps-ip
# DEPLOY_USER=ubuntu
# DEPLOY_SSH_KEY=<private key contents>
# DOCKER_PASSWORD=your-dockerhub-password-or-token
